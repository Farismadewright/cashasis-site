---
// Root redirect → /blog/ (since this Netlify site is the blog).
// When you wire cashasis.com/blog as a subfolder, the main site owns "/".
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content="0; url=/blog/" />
  <link rel="canonical" href="/blog/" />
  <title>CashAsIs Blog</title>
</head>
<body>
  <p>Redirecting to <a href="/blog/">the blog</a>&hellip;</p>
</body>
</html>
