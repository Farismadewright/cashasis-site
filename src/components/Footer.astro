---
const year = new Date().getFullYear();
---
<footer id="contact">
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <a href="/" class="logo">
          <span class="lock">
            <span class="name"><span class="navy">cash</span><span class="orange">asis</span></span>
            <span class="sub">WE BUY HOUSES AS-IS</span>
          </span>
        </a>
        <p class="foot-blurb">We buy houses as-is in your area and surrounding communities. Get a fair cash offer today with no hassle and no pressure.</p>
      </div>
      <div class="foot-col">
        <h4>Contact</h4>
        <div class="foot-contact">
          <a href="tel:+13465846365">(346) 584-6365</a>
          <a href="mailto:info@cashasis.com">info@cashasis.com</a>
          <a href="/">www.cashasis.com</a>
        </div>
      </div>
      <div class="foot-col">
        <h4>Company</h4>
        <div class="foot-contact" style="display:grid;grid-template-columns:1fr 1fr;gap:12px 24px">
          <a href="/#how">How It Works</a>
          <a href="/#about">About Us</a>
          <a href="/#reviews">Reviews</a>
          <a href="/#faq">FAQ</a>
          <a href="/careers">Careers</a>
          <a href="/referrals">Referrals</a>
          <a href="/blog/">Blog</a>
          <a href="/lending-partners">Lending Partners</a>
        </div>
      </div>
      <div class="foot-col">
        <h4>Follow Us</h4>
        <div class="socials">
          <a href="https://www.facebook.com/cashasis/" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.9h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94Z"/></svg></a>
          <a href="https://www.instagram.com/cashasisproperties/" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
        </div>
      </div>
    </div>
    <div class="foot-bottom">
      <span>&copy; 2016-{year} CashAsIs. All Rights Reserved.</span>
      <div class="links">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href="/sms-tcpa">SMS / TCPA</a>
        <a href="/disclaimer">Disclaimer</a>
        <a href="/accessibility">Accessibility</a>
      </div>
    </div>
    <p style="padding:0 0 22px;font-size:11.5px;color:#6b7480">For informational purposes only — not legal, tax, or financial advice.</p>
  </div>
</footer>
